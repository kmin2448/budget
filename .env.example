# Google OAuth (Google Cloud Console에서 생성)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Sheets (서비스 계정)
GOOGLE_SHEETS_ID=                    # 스프레드시트 URL에서 /d/ 뒤의 ID
GOOGLE_SERVICE_ACCOUNT_EMAIL=        # xxx@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=  # -----BEGIN RSA PRIVATE KEY----- ...

# Google Drive
GOOGLE_DRIVE_ROOT_FOLDER_ID=         # 지출부 저장용 최상위 Drive 폴더 ID

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                     # openssl rand -base64 32

# Supabase
NEXT_PUBLIC_SUPABASE_URL=            # https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=       # anon key (공개 가능)
SUPABASE_SERVICE_ROLE_KEY=           # service_role key (절대 클라이언트 노출 금지)
